{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request;Exception"
      },
      "enableLiveMetrics": true
    },
    "logLevel": {
      "default": "Information",
      "Function.ImageProcessor": "Debug"
    }
  },
  "extensions": {
    "blobs": {
      "maxDegreeOfParallelism": 4,
      "poisonBlobThreshold": 3
    }
  },
  "functionTimeout": "00:10:00"
}